# --- Server ---
PORT=4000
CLIENT_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# Local dev example: postgresql://postgres:postgres@localhost:5432/ticket_booking
# Render/Railway/Supabase: paste the connection string they give you
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket_booking

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Seat hold / offer timing (in minutes) ---
SEAT_HOLD_TTL_MINUTES=10
WAITLIST_OFFER_TTL_MINUTES=15

# --- Email (Brevo transactional email API — https://www.brevo.com) ---
# Free tier: 300 emails/day, no credit card. Uses HTTPS (port 443), which works on
# free-tier hosts that block outbound SMTP ports (e.g. Render).
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=Ticket Booking
