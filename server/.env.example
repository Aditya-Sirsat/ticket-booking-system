# --- Server ---
PORT=4000
CLIENT_URL=http://localhost:5173

# --- Database (PostgreSQL) ---
# Local dev example: postgresql://postgres:postgres@localhost:5432/ticket_booking
# Render/Railway/Supabase: paste the connection string they give you
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket_booking

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Seat hold / offer timing (in minutes) ---
SEAT_HOLD_TTL_MINUTES=10
WAITLIST_OFFER_TTL_MINUTES=15

# --- Email (SMTP) ---
# Any free-tier SMTP works: Gmail App Password, Brevo (Sendinblue), Mailtrap, Ethereal for testing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Ticket Booking <your_email@gmail.com>"
